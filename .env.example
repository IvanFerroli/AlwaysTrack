# Local defaults. Copy to `.env`; never commit real secrets.
NODE_ENV="development"

# API
DATABASE_URL="file:./dev.db"
SESSION_SECRET="change-me-in-production"
SESSION_COOKIE_NAME="alwaystrack_session"
API_PORT="3333"
CORS_ORIGIN="http://localhost:5173"

# Web build/runtime
VITE_API_BASE_URL=""

# Private document storage
STORAGE_PROVIDER="local"
STORAGE_LOCAL_DIR=".storage/private"
DOCUMENT_MAX_BYTES="10485760"

# Notifications
NOTIFICATION_PROVIDER="fake"
META_WHATSAPP_TOKEN=""
META_WHATSAPP_PHONE_NUMBER_ID=""
META_WEBHOOK_VERIFY_TOKEN=""
META_APP_SECRET=""
META_WHATSAPP_SMOKE_TO=""
META_WHATSAPP_SMOKE_TEMPLATE="hello_world"
META_WHATSAPP_SMOKE_TEMPLATE_LANGUAGE="en_US"
SUPPORT_PHONE=""

# Production job tuning
NOTIFICATION_JOB_LIMIT="25"

# Document AI (optional — defaults to fake/local when keys are absent)
# Providers: fake (default, no external call) | openai | gemini
DOCUMENT_AI_PROVIDER="fake"
DOCUMENT_AI_MODEL="gemini-2.5-flash"
OPENAI_API_KEY=""
GEMINI_API_KEY=""

# Google Sheets assisted template (optional)
GOOGLE_APPLICATION_CREDENTIALS=""
GOOGLE_SERVICE_ACCOUNT_EMAIL=""
GOOGLE_PRIVATE_KEY=""
GOOGLE_SHEETS_TEMPLATE_FOLDER_ID=""
GOOGLE_SHEETS_TEMPLATE_SHARE_EMAIL=""
GOOGLE_SHEETS_TEMPLATE_SHARE_ROLE="writer"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI=""
GOOGLE_TOKEN_ENCRYPTION_KEY=""
