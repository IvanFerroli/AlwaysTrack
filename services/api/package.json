{
  "name": "@alwaystrack/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "start": "node dist/main.js",
    "build": "tsc -p tsconfig.json",
    "lint": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "job:notifications": "tsx src/jobs/notifications.ts",
    "smoke:whatsapp": "tsx src/scripts/smoke-whatsapp.ts",
    "smoke:google-sheets": "tsx src/scripts/smoke-google-sheets.ts",
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@alwaystrack/shared": "file:../../packages/shared",
    "@prisma/client": "6.19.3",
    "cookie": "^1.0.2",
    "exceljs": "^4.4.0",
    "express": "^5.1.0",
    "pdf-parse": "^2.4.5"
  },
  "devDependencies": {
    "@types/express": "^5.0.5",
    "@types/node": "^24.9.2",
    "tsx": "^4.20.6",
    "vitest": "^3.2.4"
  }
}
