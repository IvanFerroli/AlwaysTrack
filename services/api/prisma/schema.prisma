generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  document  String?
  logoUrl   String?
  settingsJson String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users                 User[]
  units                 Unit[]
  licenseTypes          LicenseType[]
  notificationTemplates NotificationTemplate[]
  notificationRules     NotificationRule[]
  notificationJobs      NotificationJob[]
  inAppNotifications    InAppNotification[]
  announcements         Announcement[]
  announcementReadReceipts AnnouncementReadReceipt[]
  scriptCategories      ScriptCategory[]
  operationalScripts    OperationalScript[]
  serviceFlows          ServiceFlow[]
  serviceFlowSteps      ServiceFlowStep[]
  serviceFlowStepScripts ServiceFlowStepScript[]
  serviceFlowSessions   ServiceFlowSession[]
  serviceFlowSessionSteps ServiceFlowSessionStep[]
  serviceFlowRevisions  ServiceFlowRevision[]
  serviceFlowSearchEvents ServiceFlowSearchEvent[]
  personalScripts       PersonalScript[]
  personalScriptFlows   PersonalScriptFlow[]
  operationalScriptRevisions OperationalScriptRevision[]
  operationalScriptEvents OperationalScriptEvent[]
  operationalScriptSuggestions OperationalScriptSuggestion[]
  operationalScriptSearchEvents OperationalScriptSearchEvent[]
  faqItems              FaqItem[]
  faqThreads            FaqThread[]
  faqComments           FaqComment[]
  faqReactions          FaqReaction[]
  wikiPages             WikiPage[]
  wikiEditRequests      WikiEditRequest[]
  wikiReadReceipts      WikiReadReceipt[]
  wikiPresences         WikiPresence[]
  wikiRevisions         WikiRevision[]
  wikiAttachments       WikiAttachment[]
  professionals         Professional[]
  auditLogs             AuditLog[]
  documentAiExtractions DocumentAiExtraction[]
  googleConnections     GoogleConnection[]
  googleOauthStates     GoogleOauthState[]
  sellerProfiles        SellerProfile[]
  salesGroups           SalesGroup[]
  salesDocuments        SalesDocument[]
  salesCampaigns        SalesCampaign[]
  rankingSnapshots      RankingSnapshot[]
}

model Unit {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization  Organization   @relation(fields: [organizationId], references: [id])
  sectors       Sector[]
  professionals Professional[]

  @@unique([organizationId, name])
  @@index([organizationId])
  @@index([active])
}

model Sector {
  id        String   @id @default(cuid())
  unitId    String
  name      String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  unit          Unit           @relation(fields: [unitId], references: [id])
  professionals Professional[]

  @@unique([unitId, name])
  @@index([unitId])
  @@index([active])
}

model User {
  id              String   @id @default(cuid())
  name            String
  email           String   @unique
  passwordHash    String
  role            String
  phone           String?
  avatarUrl       String?
  active          Boolean  @default(true)
  passwordChangedAt DateTime @default(now())
  organizationId  String
  unitScopeJson   String?
  sectorScopeJson String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organization        Organization   @relation(fields: [organizationId], references: [id])
  auditLogs           AuditLog[]
  professionalsAsRt   Professional[] @relation("ProfessionalResponsibleRt")
  professionalAccount Professional?  @relation("ProfessionalUser")
  validatedLicenses   License[]      @relation("LicenseValidatedBy")
  uploadedDocuments   Document[]     @relation("DocumentUploadedByUser")
  validatedDocuments  Document[]     @relation("DocumentValidatedBy")
  appliedExtractions  DocumentAiExtraction[] @relation("DocumentAiExtractionAppliedBy")
  googleConnection    GoogleConnection?
  googleOauthStates   GoogleOauthState[]
  wikiPagesCreated    WikiPage[] @relation("WikiPageCreatedBy")
  wikiPagesUpdated    WikiPage[] @relation("WikiPageUpdatedBy")
  wikiEditRequestsAuthored WikiEditRequest[] @relation("WikiEditRequestAuthor")
  wikiEditRequestsReviewed WikiEditRequest[] @relation("WikiEditRequestReviewer")
  wikiReadReceipts    WikiReadReceipt[] @relation("WikiReadReceiptUser")
  wikiPresences       WikiPresence[] @relation("WikiPresenceUser")
  wikiRevisions       WikiRevision[] @relation("WikiRevisionAuthor")
  wikiAttachments     WikiAttachment[] @relation("WikiAttachmentUploader")
  sellerProfile       SellerProfile? @relation("SellerProfileUser")
  supervisedSalesGroups SalesGroup[] @relation("SalesGroupSupervisor")
  uploadedSalesDocuments SalesDocument[] @relation("SalesDocumentUploadedBy")
  reviewedSalesDocuments SalesDocument[] @relation("SalesDocumentReviewedBy")
  faqThreadsAuthored    FaqThread[] @relation("FaqThreadAuthor")
  faqThreadsPromoted    FaqThread[] @relation("FaqThreadPromoter")
  faqCommentsAuthored   FaqComment[] @relation("FaqCommentAuthor")
  faqReactionsAuthored  FaqReaction[] @relation("FaqReactionUser")
  inAppNotifications    InAppNotification[] @relation("InAppNotificationRecipient")
  announcementsAuthored Announcement[] @relation("AnnouncementAuthor")
  announcementsUpdated  Announcement[] @relation("AnnouncementUpdatedBy")
  announcementReadReceipts AnnouncementReadReceipt[] @relation("AnnouncementReadReceiptUser")
  scriptCategoriesCreated ScriptCategory[] @relation("ScriptCategoryCreatedBy")
  operationalScriptsCreated OperationalScript[] @relation("OperationalScriptCreatedBy")
  operationalScriptsUpdated OperationalScript[] @relation("OperationalScriptUpdatedBy")
  operationalScriptsValidated OperationalScript[] @relation("OperationalScriptValidatedBy")
  operationalScriptsRecertified OperationalScript[] @relation("OperationalScriptRecertifiedBy")
  serviceFlowsCreated ServiceFlow[] @relation("ServiceFlowCreatedBy")
  serviceFlowsUpdated ServiceFlow[] @relation("ServiceFlowUpdatedBy")
  serviceFlowsReviewed ServiceFlow[] @relation("ServiceFlowReviewedBy")
  serviceFlowRevisionsAuthored ServiceFlowRevision[] @relation("ServiceFlowRevisionAuthor")
  serviceFlowSearchEvents ServiceFlowSearchEvent[] @relation("ServiceFlowSearchEventUser")
  serviceFlowSessions ServiceFlowSession[] @relation("ServiceFlowSessionUser")
  personalScripts PersonalScript[] @relation("PersonalScriptOwner")
  operationalScriptRevisionsAuthored OperationalScriptRevision[] @relation("OperationalScriptRevisionAuthor")
  operationalScriptEvents OperationalScriptEvent[] @relation("OperationalScriptEventUser")
  operationalScriptSuggestionsAuthored OperationalScriptSuggestion[] @relation("OperationalScriptSuggestionAuthor")
  operationalScriptSuggestionsDecided OperationalScriptSuggestion[] @relation("OperationalScriptSuggestionDecider")
  operationalScriptSearchEvents OperationalScriptSearchEvent[] @relation("OperationalScriptSearchEventUser")

  @@index([organizationId])
  @@index([role])
  @@index([active])
}

model SellerProfile {
  id             String   @id @default(cuid())
  organizationId String
  userId         String?  @unique
  salesGroupId   String?
  code           String
  displayName    String
  document       String?
  email          String?
  phone          String?
  active         Boolean  @default(true)
  monthlyGoalCents Int?
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  user         User?        @relation("SellerProfileUser", fields: [userId], references: [id])
  salesGroup   SalesGroup?  @relation(fields: [salesGroupId], references: [id])
  documents    SalesDocument[]
  items        SalesItem[]

  @@unique([organizationId, code])
  @@index([organizationId])
  @@index([salesGroupId])
  @@index([active])
}

model SalesGroup {
  id             String   @id @default(cuid())
  organizationId String
  supervisorId   String?
  name           String
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  supervisor   User?        @relation("SalesGroupSupervisor", fields: [supervisorId], references: [id])
  sellers      SellerProfile[]
  campaigns    SalesCampaign[]

  @@unique([organizationId, name])
  @@index([organizationId])
  @@index([supervisorId])
  @@index([active])
}

model SalesDocument {
  id             String   @id @default(cuid())
  organizationId String
  sellerProfileId String
  uploadedById   String
  reviewedById   String?
  fileKey        String
  fileName       String
  mimeType       String
  size           Int
  status         String   @default("UPLOADED")
  accessKey      String?
  invoiceNumber  String?
  series         String?
  issuedAt       DateTime?
  issuerName     String?
  buyerName      String?
  totalAmountCents Int?
  extractionConfidence Float?
  rejectionReason String?
  reviewedAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  sellerProfile SellerProfile @relation(fields: [sellerProfileId], references: [id])
  uploadedBy   User @relation("SalesDocumentUploadedBy", fields: [uploadedById], references: [id])
  reviewedBy   User? @relation("SalesDocumentReviewedBy", fields: [reviewedById], references: [id])
  extractions  SalesDocumentExtraction[]
  items        SalesItem[]

  @@unique([organizationId, accessKey])
  @@index([organizationId])
  @@index([sellerProfileId])
  @@index([uploadedById])
  @@index([reviewedById])
  @@index([status])
  @@index([issuedAt])
}

model SalesDocumentExtraction {
  id             String   @id @default(cuid())
  salesDocumentId String
  provider       String
  rawText        String?
  extractedJson  String
  confidence     Float?
  createdAt      DateTime @default(now())

  salesDocument SalesDocument @relation(fields: [salesDocumentId], references: [id])

  @@index([salesDocumentId])
  @@index([provider])
}

model SalesItem {
  id             String   @id @default(cuid())
  salesDocumentId String
  sellerProfileId String
  sku            String?
  description    String
  category       String?
  quantity       Float
  unitAmountCents Int?
  totalAmountCents Int
  createdAt      DateTime @default(now())

  salesDocument SalesDocument @relation(fields: [salesDocumentId], references: [id])
  sellerProfile SellerProfile @relation(fields: [sellerProfileId], references: [id])

  @@index([salesDocumentId])
  @@index([sellerProfileId])
  @@index([sku])
  @@index([category])
}

model SalesCampaign {
  id             String   @id @default(cuid())
  organizationId String
  salesGroupId   String?
  name           String
  description    String?
  metric         String
  status         String   @default("DRAFT")
  startsAt       DateTime
  endsAt         DateTime
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  salesGroup   SalesGroup?  @relation(fields: [salesGroupId], references: [id])
  rankingSnapshots RankingSnapshot[]

  @@index([organizationId])
  @@index([salesGroupId])
  @@index([status])
  @@index([startsAt])
  @@index([endsAt])
}

model RankingSnapshot {
  id             String   @id @default(cuid())
  organizationId String
  campaignId     String?
  periodStart    DateTime
  periodEnd      DateTime
  scopeType      String
  scopeId        String?
  payloadJson    String
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  campaign     SalesCampaign? @relation(fields: [campaignId], references: [id])

  @@index([organizationId])
  @@index([campaignId])
  @@index([periodStart])
  @@index([periodEnd])
  @@index([scopeType])
}

model Professional {
  id              String   @id @default(cuid())
  organizationId  String
  unitId          String
  sectorId        String
  responsibleRtId String?
  userId          String?  @unique
  name            String
  cpf             String?
  email           String?
  phone           String?
  position        String?
  active          Boolean  @default(true)
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organization     Organization      @relation(fields: [organizationId], references: [id])
  unit             Unit              @relation(fields: [unitId], references: [id])
  sector           Sector            @relation(fields: [sectorId], references: [id])
  responsibleRt    User?             @relation("ProfessionalResponsibleRt", fields: [responsibleRtId], references: [id])
  user             User?             @relation("ProfessionalUser", fields: [userId], references: [id])
  licenses         License[]
  documents        Document[]
  uploadTokens     UploadToken[]
  notificationJobs NotificationJob[]

  @@unique([organizationId, cpf])
  @@index([organizationId])
  @@index([unitId])
  @@index([sectorId])
  @@index([responsibleRtId])
  @@index([active])
}

model LicenseType {
  id                 String   @id @default(cuid())
  organizationId     String
  name               String
  description        String?
  defaultWarningDays String?
  active             Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  organization      Organization       @relation(fields: [organizationId], references: [id])
  licenses          License[]
  notificationRules NotificationRule[]

  @@unique([organizationId, name])
  @@index([organizationId])
  @@index([active])
}

model License {
  id              String    @id @default(cuid())
  professionalId  String
  licenseTypeId   String
  number          String?
  issuer          String?
  uf              String?
  issuedAt        DateTime?
  expiresAt       DateTime?
  status          String
  lastValidatedAt DateTime?
  validatedById   String?
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  professional     Professional      @relation(fields: [professionalId], references: [id])
  licenseType      LicenseType       @relation(fields: [licenseTypeId], references: [id])
  validatedBy      User?             @relation("LicenseValidatedBy", fields: [validatedById], references: [id])
  documents        Document[]
  uploadTokens     UploadToken[]
  notificationJobs NotificationJob[]

  @@unique([professionalId, licenseTypeId, number])
  @@index([professionalId])
  @@index([licenseTypeId])
  @@index([status])
  @@index([expiresAt])
  @@index([validatedById])
}

model Document {
  id               String    @id @default(cuid())
  professionalId   String
  licenseId        String
  fileKey          String
  fileUrl          String?
  fileName         String
  mimeType         String
  size             Int
  status           String
  uploadedByUserId String?
  uploadTokenId    String?
  validatedById    String?
  validatedAt      DateTime?
  rejectionReason  String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  professional   Professional @relation(fields: [professionalId], references: [id])
  license        License      @relation(fields: [licenseId], references: [id])
  uploadedByUser User?        @relation("DocumentUploadedByUser", fields: [uploadedByUserId], references: [id])
  uploadToken    UploadToken? @relation(fields: [uploadTokenId], references: [id])
  validatedBy    User?        @relation("DocumentValidatedBy", fields: [validatedById], references: [id])
  aiExtractions  DocumentAiExtraction[]

  @@index([professionalId])
  @@index([licenseId])
  @@index([status])
  @@index([uploadedByUserId])
  @@index([uploadTokenId])
  @@index([validatedById])
}

model DocumentAiExtraction {
  id             String    @id @default(cuid())
  organizationId String
  documentId     String
  provider       String
  model          String?
  status         String
  resultJson     String?
  errorMessage   String?
  appliedAt      DateTime?
  appliedById    String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  document     Document     @relation(fields: [documentId], references: [id])
  appliedBy    User?        @relation("DocumentAiExtractionAppliedBy", fields: [appliedById], references: [id])

  @@index([organizationId])
  @@index([documentId])
  @@index([status])
  @@index([appliedById])
}

model UploadToken {
  id             String    @id @default(cuid())
  professionalId String
  licenseId      String
  tokenHash      String    @unique
  expiresAt      DateTime
  usedAt         DateTime?
  active         Boolean   @default(true)
  createdAt      DateTime  @default(now())

  professional Professional @relation(fields: [professionalId], references: [id])
  license      License      @relation(fields: [licenseId], references: [id])
  documents    Document[]

  @@index([professionalId])
  @@index([licenseId])
  @@index([active])
  @@index([expiresAt])
}

model NotificationTemplate {
  id               String   @id @default(cuid())
  organizationId   String
  key              String
  channel          String
  metaTemplateName String?
  language         String
  bodyPreview      String?
  active           Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, key])
  @@index([organizationId])
  @@index([channel])
  @@index([active])
}

model NotificationRule {
  id                     String   @id @default(cuid())
  organizationId         String
  licenseTypeId          String?
  daysBeforeExpiration   Int?
  repeatAfterExpiredDays Int?
  channel                String
  templateKey            String
  notifyProfessional     Boolean  @default(true)
  notifyRt               Boolean  @default(false)
  active                 Boolean  @default(true)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  organization     Organization      @relation(fields: [organizationId], references: [id])
  licenseType      LicenseType?      @relation(fields: [licenseTypeId], references: [id])
  notificationJobs NotificationJob[]

  @@index([organizationId])
  @@index([licenseTypeId])
  @@index([channel])
  @@index([active])
}

model NotificationJob {
  id                 String    @id @default(cuid())
  organizationId     String
  professionalId     String
  licenseId          String
  notificationRuleId String?
  periodKey          String
  dedupeKey          String    @unique
  channel            String
  recipientPhone     String?
  recipientEmail     String?
  templateKey        String
  payloadJson        String
  status             String
  scheduledFor       DateTime
  processingAt       DateTime?
  sentAt             DateTime?
  deliveredAt        DateTime?
  readAt             DateTime?
  failedAt           DateTime?
  attempts           Int       @default(0)
  maxAttempts        Int       @default(3)
  nextRetryAt        DateTime?
  errorMessage       String?
  provider           String?
  providerMessageId  String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  organization     Organization      @relation(fields: [organizationId], references: [id])
  professional     Professional      @relation(fields: [professionalId], references: [id])
  license          License           @relation(fields: [licenseId], references: [id])
  notificationRule NotificationRule? @relation(fields: [notificationRuleId], references: [id])
  logs             NotificationLog[]

  @@index([organizationId])
  @@index([professionalId])
  @@index([licenseId])
  @@index([notificationRuleId])
  @@index([periodKey])
  @@index([status])
  @@index([scheduledFor])
  @@index([providerMessageId])
}

model NotificationLog {
  id                String   @id @default(cuid())
  notificationJobId String
  provider          String
  providerMessageId String?
  status            String
  rawPayload        String?
  rawResponse       String?
  createdAt         DateTime @default(now())

  notificationJob NotificationJob @relation(fields: [notificationJobId], references: [id])

  @@index([notificationJobId])
  @@index([providerMessageId])
  @@index([status])
}

model InAppNotification {
  id             String    @id @default(cuid())
  organizationId String
  recipientId    String
  type           String
  title          String
  body           String?
  entityType     String?
  entityId       String?
  href           String?
  dedupeKey      String?
  readAt         DateTime?
  createdAt      DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  recipient    User         @relation("InAppNotificationRecipient", fields: [recipientId], references: [id])

  @@unique([organizationId, recipientId, dedupeKey])
  @@index([organizationId])
  @@index([recipientId])
  @@index([readAt])
  @@index([type])
  @@index([entityType, entityId])
}

model Announcement {
  id             String    @id @default(cuid())
  organizationId String
  slug           String
  title          String
  summary        String?
  content        String
  tagsJson       String?
  linksJson      String?
  targetRolesJson String?
  status         String    @default("DRAFT")
  priority       String    @default("NORMAL")
  pinned         Boolean   @default(false)
  requiresAck    Boolean   @default(false)
  startsAt       DateTime?
  expiresAt      DateTime?
  publishedAt    DateTime?
  archivedAt     DateTime?
  createdById    String
  updatedById    String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  createdBy    User         @relation("AnnouncementAuthor", fields: [createdById], references: [id])
  updatedBy    User         @relation("AnnouncementUpdatedBy", fields: [updatedById], references: [id])
  readReceipts AnnouncementReadReceipt[]

  @@unique([organizationId, slug])
  @@index([organizationId])
  @@index([status])
  @@index([priority])
  @@index([pinned])
  @@index([startsAt])
  @@index([expiresAt])
  @@index([publishedAt])
}

model AnnouncementReadReceipt {
  id             String   @id @default(cuid())
  organizationId String
  announcementId String
  userId         String
  acknowledgedAt DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  announcement Announcement  @relation(fields: [announcementId], references: [id])
  user         User          @relation("AnnouncementReadReceiptUser", fields: [userId], references: [id])

  @@unique([announcementId, userId])
  @@index([organizationId])
  @@index([announcementId])
  @@index([userId])
  @@index([acknowledgedAt])
}

model ScriptCategory {
  id             String   @id @default(cuid())
  organizationId String
  createdById    String
  slug           String
  name           String
  description    String?
  order          Int      @default(0)
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  createdBy    User         @relation("ScriptCategoryCreatedBy", fields: [createdById], references: [id])
  scripts      OperationalScript[]
  suggestions  OperationalScriptSuggestion[]

  @@unique([organizationId, slug])
  @@unique([organizationId, name])
  @@index([organizationId])
  @@index([active])
  @@index([order])
}

model OperationalScript {
  id             String    @id @default(cuid())
  organizationId String
  categoryId     String
  wikiPageId     String?
  faqThreadId    String?
  title          String
  channel        String
  body           String
  tagsJson       String?
  placeholdersJson String?
  status         String    @default("DRAFT")
  createdById    String
  updatedById    String
  validatedById  String?
  validatedAt    DateTime?
  reviewDueAt    DateTime?
  recertifiedById String?
  recertifiedAt  DateTime?
  usageCount     Int       @default(0)
  copiedAt       DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  category     ScriptCategory @relation(fields: [categoryId], references: [id])
  wikiPage     WikiPage?    @relation("OperationalScriptWikiPage", fields: [wikiPageId], references: [id])
  faqThread    FaqThread?   @relation("OperationalScriptFaqThread", fields: [faqThreadId], references: [id])
  createdBy    User         @relation("OperationalScriptCreatedBy", fields: [createdById], references: [id])
  updatedBy    User         @relation("OperationalScriptUpdatedBy", fields: [updatedById], references: [id])
  validatedBy  User?        @relation("OperationalScriptValidatedBy", fields: [validatedById], references: [id])
  recertifiedBy User?       @relation("OperationalScriptRecertifiedBy", fields: [recertifiedById], references: [id])
  revisions    OperationalScriptRevision[]
  events       OperationalScriptEvent[]
  suggestions  OperationalScriptSuggestion[]
  serviceFlowStepScripts ServiceFlowStepScript[]

  @@unique([organizationId, categoryId, title])
  @@index([organizationId])
  @@index([categoryId])
  @@index([wikiPageId])
  @@index([faqThreadId])
  @@index([status])
  @@index([channel])
  @@index([validatedById])
  @@index([reviewDueAt])
  @@index([recertifiedById])
  @@index([usageCount])
}

model ServiceFlow {
  id             String   @id @default(cuid())
  organizationId String
  wikiPageId     String?
  title          String
  slug           String
  summary        String?
  content        String?
  tagsJson       String?
  status         String   @default("DRAFT")
  priority       Int      @default(0)
  version        Int      @default(1)
  reviewComment  String?
  reviewDueAt    DateTime?
  reviewedById   String?
  reviewedAt     DateTime?
  createdById    String
  updatedById    String
  publishedAt    DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  wikiPage     WikiPage? @relation("ServiceFlowWikiPage", fields: [wikiPageId], references: [id])
  createdBy    User @relation("ServiceFlowCreatedBy", fields: [createdById], references: [id])
  updatedBy    User @relation("ServiceFlowUpdatedBy", fields: [updatedById], references: [id])
  reviewedBy   User? @relation("ServiceFlowReviewedBy", fields: [reviewedById], references: [id])
  steps        ServiceFlowStep[]
  sessions     ServiceFlowSession[]
  revisions    ServiceFlowRevision[]
  searchEvents ServiceFlowSearchEvent[]
  personalScriptFlows PersonalScriptFlow[]

  @@unique([organizationId, slug])
  @@index([organizationId])
  @@index([wikiPageId])
  @@index([status])
  @@index([priority])
  @@index([publishedAt])
  @@index([reviewedById])
  @@index([reviewDueAt])
}

model ServiceFlowStep {
  id             String   @id @default(cuid())
  organizationId String
  flowId         String
  title          String
  body           String?
  kind           String   @default("MANUAL")
  decisionJson   String?
  order          Int      @default(0)
  required       Boolean  @default(false)
  collapsed      Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  flow         ServiceFlow @relation(fields: [flowId], references: [id])
  scripts      ServiceFlowStepScript[]
  sessionSteps ServiceFlowSessionStep[]

  @@index([organizationId])
  @@index([flowId])
  @@index([kind])
  @@index([order])
}

model ServiceFlowStepScript {
  id             String   @id @default(cuid())
  organizationId String
  stepId         String
  scriptId       String
  label          String?
  order          Int      @default(0)
  required       Boolean  @default(false)
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  step         ServiceFlowStep @relation(fields: [stepId], references: [id])
  script       OperationalScript @relation(fields: [scriptId], references: [id])

  @@unique([stepId, scriptId])
  @@index([organizationId])
  @@index([stepId])
  @@index([scriptId])
  @@index([order])
}

model ServiceFlowSession {
  id             String   @id @default(cuid())
  organizationId String
  flowId         String
  userId         String
  status         String   @default("OPEN")
  startedAt      DateTime @default(now())
  completedAt    DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  flow         ServiceFlow @relation(fields: [flowId], references: [id])
  user         User        @relation("ServiceFlowSessionUser", fields: [userId], references: [id])
  steps        ServiceFlowSessionStep[]

  @@index([organizationId])
  @@index([flowId])
  @@index([userId])
  @@index([status])
  @@index([startedAt])
}

model ServiceFlowSessionStep {
  id             String   @id @default(cuid())
  organizationId String
  sessionId      String
  stepId         String
  status         String   @default("PENDING")
  decision       String?
  note           String?
  completedAt    DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  session      ServiceFlowSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  step         ServiceFlowStep @relation(fields: [stepId], references: [id], onDelete: Cascade)

  @@unique([sessionId, stepId])
  @@index([organizationId])
  @@index([stepId])
  @@index([status])
}

model ServiceFlowRevision {
  id             String   @id @default(cuid())
  organizationId String
  flowId         String
  version        Int
  title          String
  status         String
  snapshotJson   String
  comment        String?
  authorId       String
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  flow         ServiceFlow @relation(fields: [flowId], references: [id], onDelete: Cascade)
  author       User @relation("ServiceFlowRevisionAuthor", fields: [authorId], references: [id])

  @@unique([flowId, version])
  @@index([organizationId])
  @@index([flowId])
  @@index([authorId])
  @@index([createdAt])
}

model ServiceFlowSearchEvent {
  id             String   @id @default(cuid())
  organizationId String
  flowId         String?
  userId         String?
  query          String?
  filtersJson    String?
  resultCount    Int      @default(0)
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  flow         ServiceFlow? @relation(fields: [flowId], references: [id], onDelete: SetNull)
  user         User? @relation("ServiceFlowSearchEventUser", fields: [userId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([flowId])
  @@index([userId])
  @@index([resultCount])
  @@index([createdAt])
}

model PersonalScript {
  id             String   @id @default(cuid())
  organizationId String
  ownerId        String
  title          String
  channel        String   @default("WHATSAPP")
  body           String
  tagsJson       String?
  placeholdersJson String?
  suggestionId   String?
  suggestedAt    DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  owner        User @relation("PersonalScriptOwner", fields: [ownerId], references: [id])
  suggestion   OperationalScriptSuggestion? @relation("PersonalScriptSuggestion", fields: [suggestionId], references: [id])
  flows        PersonalScriptFlow[]

  @@unique([organizationId, ownerId, title])
  @@index([organizationId])
  @@index([ownerId])
  @@index([suggestionId])
  @@index([channel])
  @@index([updatedAt])
}

model PersonalScriptFlow {
  id             String   @id @default(cuid())
  organizationId String
  personalScriptId String
  flowId         String
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  personalScript PersonalScript @relation(fields: [personalScriptId], references: [id], onDelete: Cascade)
  flow         ServiceFlow @relation(fields: [flowId], references: [id], onDelete: Cascade)

  @@unique([personalScriptId, flowId])
  @@index([organizationId])
  @@index([flowId])
}

model OperationalScriptRevision {
  id             String   @id @default(cuid())
  organizationId String
  scriptId       String
  authorId       String
  version        Int
  title          String
  channel        String
  body           String
  tagsJson       String?
  placeholdersJson String?
  status         String
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  script       OperationalScript @relation(fields: [scriptId], references: [id])
  author       User         @relation("OperationalScriptRevisionAuthor", fields: [authorId], references: [id])

  @@unique([scriptId, version])
  @@index([organizationId])
  @@index([scriptId])
  @@index([authorId])
}

model OperationalScriptEvent {
  id             String   @id @default(cuid())
  organizationId String
  scriptId       String
  userId         String
  action         String
  metadataJson   String?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  script       OperationalScript @relation(fields: [scriptId], references: [id])
  user         User @relation("OperationalScriptEventUser", fields: [userId], references: [id])

  @@index([organizationId])
  @@index([scriptId])
  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

model OperationalScriptSuggestion {
  id             String   @id @default(cuid())
  organizationId String
  categoryId     String?
  scriptId       String?
  authorId       String
  decidedById    String?
  title          String
  channel        String
  body           String
  tagsJson       String?
  status         String   @default("SUGGESTED")
  suggestionType String   @default("NEW")
  decisionComment String?
  createdScriptId String?
  decidedAt      DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  category     ScriptCategory? @relation(fields: [categoryId], references: [id])
  script       OperationalScript? @relation(fields: [scriptId], references: [id])
  author       User @relation("OperationalScriptSuggestionAuthor", fields: [authorId], references: [id])
  decidedBy    User? @relation("OperationalScriptSuggestionDecider", fields: [decidedById], references: [id])
  personalScripts PersonalScript[] @relation("PersonalScriptSuggestion")

  @@index([organizationId])
  @@index([categoryId])
  @@index([scriptId])
  @@index([authorId])
  @@index([decidedById])
  @@index([status])
  @@index([suggestionType])
}

model OperationalScriptSearchEvent {
  id             String   @id @default(cuid())
  organizationId String
  userId         String
  query          String?
  filtersJson    String?
  resultCount    Int      @default(0)
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  user         User @relation("OperationalScriptSearchEventUser", fields: [userId], references: [id])

  @@index([organizationId])
  @@index([userId])
  @@index([resultCount])
  @@index([createdAt])
}

model FaqItem {
  id             String   @id @default(cuid())
  organizationId String
  category       String
  question       String
  answer         String
  order          Int      @default(0)
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
  @@index([category])
  @@index([active])
}

model FaqThread {
  id             String   @id @default(cuid())
  organizationId String
  authorId       String
  title          String
  body           String?
  tagsJson       String?
  status         String   @default("OPEN")
  wikiPageId     String?
  promotedAt     DateTime?
  promotedById   String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  author       User         @relation("FaqThreadAuthor", fields: [authorId], references: [id])
  wikiPage     WikiPage?    @relation("FaqThreadWikiPage", fields: [wikiPageId], references: [id])
  promotedBy   User?        @relation("FaqThreadPromoter", fields: [promotedById], references: [id])
  comments     FaqComment[]
  reactions    FaqReaction[]
  operationalScripts OperationalScript[] @relation("OperationalScriptFaqThread")

  @@index([organizationId])
  @@index([authorId])
  @@index([status])
  @@index([wikiPageId])
  @@index([promotedById])
  @@index([createdAt])
}

model FaqComment {
  id             String   @id @default(cuid())
  organizationId String
  threadId       String
  authorId       String
  body           String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  thread       FaqThread   @relation(fields: [threadId], references: [id])
  author       User        @relation("FaqCommentAuthor", fields: [authorId], references: [id])
  reactions    FaqReaction[]

  @@index([organizationId])
  @@index([threadId])
  @@index([authorId])
  @@index([createdAt])
}

model FaqReaction {
  id             String   @id @default(cuid())
  organizationId String
  threadId       String
  commentId      String?
  userId         String
  targetType     String
  targetId       String
  type           String
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  thread       FaqThread   @relation(fields: [threadId], references: [id])
  comment      FaqComment? @relation(fields: [commentId], references: [id])
  user         User        @relation("FaqReactionUser", fields: [userId], references: [id])

  @@unique([organizationId, targetType, targetId, userId, type])
  @@index([organizationId])
  @@index([threadId])
  @@index([commentId])
  @@index([targetType])
  @@index([targetId])
  @@index([userId])
  @@index([type])
}

model WikiPage {
  id             String   @id @default(cuid())
  organizationId String
  slug           String
  title          String
  content        String
  tagsJson       String?
  version        Int      @default(1)
  active         Boolean  @default(true)
  createdById    String
  updatedById    String
  publishedAt    DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  createdBy    User         @relation("WikiPageCreatedBy", fields: [createdById], references: [id])
  updatedBy    User         @relation("WikiPageUpdatedBy", fields: [updatedById], references: [id])
  editRequests WikiEditRequest[]
  readReceipts WikiReadReceipt[]
  presences    WikiPresence[]
  revisions    WikiRevision[]
  attachments  WikiAttachment[]
  faqThreads   FaqThread[] @relation("FaqThreadWikiPage")
  operationalScripts OperationalScript[] @relation("OperationalScriptWikiPage")
  serviceFlows ServiceFlow[] @relation("ServiceFlowWikiPage")

  @@unique([organizationId, slug])
  @@index([organizationId])
  @@index([active])
  @@index([updatedAt])
}

model WikiRevision {
  id             String   @id @default(cuid())
  organizationId String
  pageId         String
  authorId       String
  requestId      String?
  version        Int
  title          String
  content        String
  createdAt      DateTime @default(now())

  organization Organization     @relation(fields: [organizationId], references: [id])
  page         WikiPage         @relation(fields: [pageId], references: [id])
  author       User             @relation("WikiRevisionAuthor", fields: [authorId], references: [id])
  request      WikiEditRequest? @relation(fields: [requestId], references: [id])

  @@index([organizationId])
  @@index([pageId])
  @@index([authorId])
  @@index([requestId])
  @@unique([pageId, version])
}

model WikiAttachment {
  id             String   @id @default(cuid())
  organizationId String
  uploadedById   String
  pageId         String?
  requestId      String?
  fileKey        String
  fileName       String
  mimeType       String
  size           Int
  createdAt      DateTime @default(now())

  organization Organization     @relation(fields: [organizationId], references: [id])
  uploadedBy   User             @relation("WikiAttachmentUploader", fields: [uploadedById], references: [id])
  page         WikiPage?        @relation(fields: [pageId], references: [id])
  request      WikiEditRequest? @relation(fields: [requestId], references: [id])

  @@index([organizationId])
  @@index([uploadedById])
  @@index([pageId])
  @@index([requestId])
}

model WikiEditRequest {
  id             String    @id @default(cuid())
  organizationId String
  pageId         String
  authorId       String
  reviewerId     String?
  baseVersion    Int
  title          String
  content        String
  status         String    @default("PENDING")
  decisionNote   String?
  reviewedAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization   @relation(fields: [organizationId], references: [id])
  page         WikiPage       @relation(fields: [pageId], references: [id])
  author       User           @relation("WikiEditRequestAuthor", fields: [authorId], references: [id])
  reviewer     User?          @relation("WikiEditRequestReviewer", fields: [reviewerId], references: [id])
  revisions    WikiRevision[]
  attachments  WikiAttachment[]

  @@index([organizationId])
  @@index([pageId])
  @@index([authorId])
  @@index([reviewerId])
  @@index([status])
}

model WikiReadReceipt {
  id             String   @id @default(cuid())
  organizationId String
  pageId         String
  userId         String
  lastReadAt     DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  page         WikiPage     @relation(fields: [pageId], references: [id])
  user         User         @relation("WikiReadReceiptUser", fields: [userId], references: [id])

  @@unique([pageId, userId])
  @@index([organizationId])
  @@index([pageId])
  @@index([userId])
  @@index([lastReadAt])
}

model WikiPresence {
  id             String   @id @default(cuid())
  organizationId String
  pageId         String
  userId         String
  mode           String
  lastSeenAt     DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  page         WikiPage     @relation(fields: [pageId], references: [id])
  user         User         @relation("WikiPresenceUser", fields: [userId], references: [id])

  @@unique([pageId, userId])
  @@index([organizationId])
  @@index([pageId])
  @@index([userId])
  @@index([lastSeenAt])
}

model GoogleConnection {
  id                    String   @id @default(cuid())
  organizationId        String
  userId                String   @unique
  provider              String
  refreshTokenEncrypted String
  scopesJson            String
  connectedAt           DateTime @default(now())
  lastUsedAt            DateTime?
  revokedAt             DateTime?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  user         User         @relation(fields: [userId], references: [id])

  @@unique([organizationId, userId, provider])
  @@index([organizationId])
  @@index([provider])
  @@index([revokedAt])
}

model GoogleOauthState {
  id             String   @id @default(cuid())
  organizationId String
  userId         String
  provider       String
  stateHash      String   @unique
  codeVerifier   String
  expiresAt      DateTime
  usedAt         DateTime?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  user         User         @relation(fields: [userId], references: [id])

  @@index([organizationId])
  @@index([userId])
  @@index([provider])
  @@index([expiresAt])
}

model AuditLog {
  id             String   @id @default(cuid())
  organizationId String
  actorId        String?
  action         String
  entityType     String
  entityId       String
  metadataJson   String?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  actor        User?        @relation(fields: [actorId], references: [id])

  @@index([organizationId, createdAt])
  @@index([actorId])
  @@index([action])
  @@index([entityType, entityId])
}
