{
  "name": "sylembra",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @sylembra/api",
    "check": "npm run typecheck --workspaces --if-present && npm run test --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "prisma:generate": "prisma generate --schema services/api/prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema services/api/prisma/schema.prisma",
    "prisma:seed": "npm run seed --workspace @sylembra/api"
  },
  "devDependencies": {
    "prisma": "6.19.3",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@prisma/client": "^6.18.0"
  }
}
