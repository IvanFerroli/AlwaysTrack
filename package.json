{
  "name": "olympus-climb",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "npm run -ws --if-present build",
    "typecheck": "npm run -ws --if-present typecheck",
    "lint": "eslint \"{apps,services,packages}/**/*.ts\"",
    "test": "npm run -ws --if-present test",
    "check": "npm run lint && npm run typecheck && npm run test",
    "dev:api": "tsx services/api/src/main.ts",
    "dev:web": "tsx apps/web/src/main.ts",
    "dev": "concurrently -k -n api,web -c blue,green \"npm run dev:api\" \"npm run dev:web\"",
    "start:api": "npm --workspace @olympus/api run start",
    "start:web": "npm --workspace @olympus/web run start"
  },
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*",
    "infrastructure/*"
  ],
  "devDependencies": {
    "@types/node": "^24.9.1",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "concurrently": "^9.2.1",
    "eslint": "^8.57.1",
    "tsx": "^4.20.6",
    "typescript": "^5.6.3"
  }
}
