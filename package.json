{
  "name": "alwaystrack",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev:api",
    "dev:api": "npm run dev --workspace @alwaystrack/api",
    "dev:web": "npm run dev --workspace @alwaystrack/web",
    "up": "node scripts/start-all.js",
    "setup": "node scripts/start-all.js --setup-only",
    "check": "npm run lint && npm run typecheck --workspaces --if-present && npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "env:check": "node scripts/check-env.js",
    "smoke:beta-local": "node scripts/smoke-beta-local.js",
    "db:flush:local": "node scripts/flush-local-demo.js",
    "db:flush:demo": "node scripts/flush-local-demo.js",
    "job:notifications": "npm run job:notifications --workspace @alwaystrack/api",
    "smoke:whatsapp": "npm run smoke:whatsapp --workspace @alwaystrack/api",
    "smoke:google-sheets": "npm run smoke:google-sheets --workspace @alwaystrack/api",
    "prisma:generate": "prisma generate --schema services/api/prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema services/api/prisma/schema.prisma",
    "prisma:seed": "npm run seed --workspace @alwaystrack/api"
  },
  "devDependencies": {
    "prisma": "6.19.3",
    "typescript": "^5.9.3"
  }
}
