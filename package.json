{
  "name": "alwaystrack",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev:api",
    "dev:api": "npm run dev --workspace @alwaystrack/api",
    "dev:web": "npm run dev --workspace @alwaystrack/web",
    "up": "node scripts/start-all.js",
    "setup": "node scripts/start-all.js --setup-only",
    "check": "npm run lint && npm run typecheck --workspaces --if-present && npm run test --workspaces --if-present",
    "check:docs": "npm run docs:api",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "test:unit": "npm run test --workspace @alwaystrack/api -- --exclude \"src/core/quality/**\"",
    "test:integration": "npm run test --workspace @alwaystrack/api -- main-flow.e2e.test.ts",
    "test:regression": "npm run test --workspace @alwaystrack/api -- sales-documents.service.test.ts wiki.service.test.ts faq.service.test.ts notifications.service.test.ts",
    "test:jobs:redis": "RUN_REDIS_JOBS_TESTS=true JOB_QUEUE_DRIVER=bullmq npm run test --workspace @alwaystrack/api -- queue.redis.test.ts",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test tests/e2e/app-smoke.spec.ts --project=desktop",
    "test:e2e:api": "playwright test --project=api",
    "test:all": "npm run check && npm run check:docs",
    "docs:api": "typedoc --options typedoc.json",
    "db:test:migrations": "node scripts/test-migrations.js",
    "repo:hygiene": "node scripts/check-repo-hygiene.js",
    "security:deps": "npm audit --audit-level=high --omit=dev",
    "perf:smoke": "artillery run tests/performance/alwaystrack-smoke.yml",
    "perf:1000": "artillery run tests/performance/alwaystrack-1000.yml",
    "perf:smoke:report": "node scripts/perf-report.js smoke",
    "perf:1000:report": "node scripts/perf-report.js 1000",
    "env:check": "node scripts/check-env.js",
    "smoke:beta-local": "node scripts/smoke-beta-local.js",
    "db:flush:local": "node scripts/flush-local-demo.js",
    "db:flush:demo": "node scripts/flush-local-demo.js",
    "demo:reset:local": "node scripts/reset-local-demo.js",
    "job:notifications": "npm run job:notifications --workspace @alwaystrack/api",
    "job:ranking-snapshots": "npm run job:ranking-snapshots --workspace @alwaystrack/api",
    "smoke:whatsapp": "npm run smoke:whatsapp --workspace @alwaystrack/api",
    "smoke:google-sheets": "npm run smoke:google-sheets --workspace @alwaystrack/api",
    "prisma:generate": "prisma generate --schema services/api/prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema services/api/prisma/schema.prisma",
    "prisma:seed": "npm run seed --workspace @alwaystrack/api"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "artillery": "^2.0.32",
    "prisma": "6.19.3",
    "typedoc": "^0.28.19",
    "typescript": "^5.9.3",
    "wait-on": "^9.0.10"
  }
}
